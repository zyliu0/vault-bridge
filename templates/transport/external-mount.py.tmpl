"""vault-bridge transport helper — external-mount.
Generated by /vault-bridge:setup. Safe to edit.
Archive root: ${ARCHIVE_ROOT}
Mount point: ${MOUNT_POINT}
"""
import os
from pathlib import Path


def fetch_to_local(archive_path: str) -> Path:
    mount_point = "${MOUNT_POINT}"
    if not os.path.ismount(mount_point):
        raise FileNotFoundError(
            f"Mount point '{mount_point}' is not currently mounted. "
            "Please connect the drive and retry."
        )
    p = Path(archive_path)
    if not p.exists():
        raise FileNotFoundError(f"Archive path does not exist: {archive_path}")
    return p
