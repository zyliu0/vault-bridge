_OOXML_MAGIC = b"PK\x03\x04"
_CLI_TIMEOUT_SECS = 20
_SOFFICE_TIMEOUT_SECS = 60
_SOFFICE_BINARIES = ("soffice", "libreoffice")
_SOFFICE_MACOS_APPS = (
    "/Applications/LibreOffice.app/Contents/MacOS/soffice",
)


def read_text(path: str) -> str:
    """Extract text from a .doc / .ppt file.

    Returns:
        Decoded text, or '' on any failure. Never raises.
    """
    try:
        magic = _peek_magic(path)
    except Exception as exc:
        logger.debug("read_text: magic peek failed for %s: %s", path, exc)
        return ""

    # 1. OOXML misname -> delegate to modern handler.
    if magic.startswith(_OOXML_MAGIC):
        text = _delegate_to_ooxml(path)
        if text:
            return text

    suffix = Path(path).suffix.lower()

    # 2. antiword / catdoc / catppt (Linux-friendly fast path).
    try:
        if suffix == ".doc":
            text = _run_doc_extractor(path)
            if text:
                return text
        elif suffix == ".ppt":
            text = _run_ppt_extractor(path)
            if text:
                return text
    except Exception as exc:
        logger.debug("CLI extraction failed for %s: %s", path, exc)

    # 3. LibreOffice headless fallback (macOS-friendly — antiword is no
    #    longer on Homebrew as of 2025-06-21, and catdoc never shipped).
    try:
        text = _run_soffice(path)
        if text:
            return text
    except Exception as exc:
        logger.debug("LibreOffice extraction failed for %s: %s", path, exc)

    return ""


