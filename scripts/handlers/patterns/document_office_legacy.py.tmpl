                    chunks = re.findall(r'[ -~]{{4,}}', text)
                    parts.extend(chunks)
            except Exception as exc:
                logger.debug("doc WordDocument stream failed for %s: %s", path, exc)
        elif suffix == ".ppt":
            # Try PowerPoint Document stream for text frames
            try:
                if ole.exists("PowerPoint Document"):
                    data = ole.openstream("PowerPoint Document").read()
                    text = data.decode("latin-1", errors="replace")
                    import re
                    chunks = re.findall(r'[ -~]{{4,}}', text)
                    parts.extend(chunks)
            except Exception as exc:
                logger.debug("ppt PowerPoint Document stream failed for %s: %s", path, exc)
        ole.close()
