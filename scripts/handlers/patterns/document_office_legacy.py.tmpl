def _decode_cli_bytes(raw: bytes) -> str:
    if not raw:
        return ""
    for codec in ("utf-8", "gbk", "shift_jis", "latin-1"):
        try:
            return raw.decode(codec, errors="strict")
        except Exception:
            continue
    return raw.decode("latin-1", errors="replace")
