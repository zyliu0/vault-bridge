def _peek_magic(path: str) -> bytes:
    with open(path, "rb") as fh:
        return fh.read(8)


def _delegate_to_ooxml(path: str):
    """Forward to the modern document_office handler if available."""
    try:
        handlers_dir = Path(__file__).parent
        # Prefer the exact filename the installer writes.
        candidates = [
            handlers_dir / "document_office_docx.py",
            handlers_dir / "document_office_pptx.py",
        ]
        for cand in candidates:
            if not cand.exists():
                continue
            import importlib.util as _il
            spec = _il.spec_from_file_location(cand.stem, str(cand))
            if not spec or not spec.loader:
                continue
            mod = _il.module_from_spec(spec)
            spec.loader.exec_module(mod)  # type: ignore[union-attr]
            if hasattr(mod, "read_text"):
                text = mod.read_text(path)
                if text:
                    return text
    except Exception as exc:
        logger.debug("OOXML delegation failed for %s: %s", path, exc)
    return ""


def _run_doc_extractor(path: str) -> str:
    for binary in ("antiword", "catdoc"):
        exe = shutil.which(binary)
        if exe is None:
            continue
        try:
            proc = subprocess.run(
                [exe, path],
                capture_output=True,
                timeout=_CLI_TIMEOUT_SECS,
                check=False,
            )
        except Exception as exc:
            logger.debug("%s failed for %s: %s", binary, path, exc)
            continue
        if proc.returncode == 0:
            out = _decode_cli_bytes(proc.stdout)
            if out.strip():
                return out
    logger.debug(
        ".doc reader not available (install antiword or catdoc for %s)", path
    )
    return ""


def _run_ppt_extractor(path: str) -> str:
    for binary in ("catppt",):
        exe = shutil.which(binary)
        if exe is None:
            continue
        try:
            proc = subprocess.run(
                [exe, path],
                capture_output=True,
                timeout=_CLI_TIMEOUT_SECS,
                check=False,
            )
        except Exception as exc:
            logger.debug("%s failed for %s: %s", binary, path, exc)
            continue
        if proc.returncode == 0:
            out = _decode_cli_bytes(proc.stdout)
            if out.strip():
                return out
    logger.debug(
        ".ppt reader not available (install catdoc/catppt for %s)", path
    )
    return ""


def _decode_cli_bytes(raw: bytes) -> str:
    if not raw:
        return ""
    for codec in ("utf-8", "gbk", "shift_jis", "latin-1"):
        try:
            return raw.decode(codec, errors="strict")
        except Exception:
            continue
    return raw.decode("latin-1", errors="replace")


def _find_soffice() -> str:
    """Return the path to a LibreOffice headless binary, or ''."""
    for name in _SOFFICE_BINARIES:
        exe = shutil.which(name)
        if exe:
            return exe
    for app in _SOFFICE_MACOS_APPS:
        if Path(app).exists():
            return app
    return ""


def _run_soffice(path: str) -> str:
    """Shell out to LibreOffice headless and return converted text.

    Writes to a per-call temp dir so concurrent invocations don't
    collide, then reads the resulting `<stem>.txt` back. Returns ''
    when soffice is absent, the conversion fails, or the output file
    is missing.
    """
    exe = _find_soffice()
    if not exe:
        return ""
    with tempfile.TemporaryDirectory() as td:
        try:
            proc = subprocess.run(
                [exe, "--headless", "--convert-to", "txt", "--outdir", td, path],
                capture_output=True,
                timeout=_SOFFICE_TIMEOUT_SECS,
                check=False,
            )
        except Exception as exc:
            logger.debug("soffice invocation failed for %s: %s", path, exc)
            return ""
        if proc.returncode != 0:
            logger.debug(
                "soffice returned %d for %s: %s",
                proc.returncode, path, proc.stderr[:200],
            )
            return ""
        out_file = Path(td) / f"{{Path(path).stem}}.txt"
        if not out_file.exists():
            return ""
        try:
            return _decode_cli_bytes(out_file.read_bytes())
        except Exception as exc:
            logger.debug("soffice output read failed: %s", exc)
            return ""
