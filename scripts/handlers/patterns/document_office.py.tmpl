def _read_xlsx(path: str) -> str:
    import openpyxl  # type: ignore
    wb = openpyxl.load_workbook(path, read_only=True, data_only=True)
    parts = []
    try:
        for ws in wb.worksheets:
            parts.append(f"# {{ws.title}}")
            for row_idx, row in enumerate(ws.iter_rows(values_only=True)):
                if row_idx >= _XLSX_ROW_CAP:
                    break
                cells = [str(c) for c in row[:_XLSX_COL_CAP] if c is not None]
                if cells:
                    parts.append("\t".join(cells))
    finally:
        try:
            wb.close()
        except Exception:
            pass
    return "\n".join(parts)


def _images_xlsx(path: str, out_dir: str) -> list:
    import openpyxl  # type: ignore
    wb = openpyxl.load_workbook(path, read_only=False, data_only=True)
    stem = Path(path).stem
    written = []
    try:
        for sheet_idx, ws in enumerate(wb.worksheets):
            images = getattr(ws, "_images", None) or []
            for img_idx, img in enumerate(images):
                if len(written) >= _IMAGE_CAP:
                    break
                try:
                    raw = None
                    ref = getattr(img, "ref", None) or getattr(img, "_data", None)
                    if callable(ref):
                        raw = ref()
                    elif hasattr(img, "_data") and callable(img._data):
                        raw = img._data()
                    if raw is None:
                        continue
                    if isinstance(raw, str):
                        raw = raw.encode()
                    ext = getattr(img, "format", "png") or "png"
                    ext = ext.lower().lstrip(".")
                    out_path = os.path.join(
                        out_dir,
                        f"{{stem}}--sh{{sheet_idx + 1:02d}}-i{{img_idx + 1:02d}}.{{ext}}",
                    )
                    with open(out_path, "wb") as fh:
                        fh.write(raw)
                    written.append(out_path)
                except Exception:
                    continue
    finally:
        try:
            wb.close()
        except Exception:
            pass
    return written
