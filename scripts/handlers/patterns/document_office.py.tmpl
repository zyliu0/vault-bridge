    for rel_id, rel in doc.part.rels.items():
        if len(written) >= _IMAGE_CAP:
            break
        try:
            if "image" not in str(rel.reltype).lower():
                continue
            blob = rel.target_part.blob
            target = getattr(rel.target_part, "partname", "") or ""
            ext = Path(str(target)).suffix.lstrip(".") or "bin"
            out_path = os.path.join(
                out_dir, f"{{stem}}--{{rel_id}}.{{ext}}"
            )
            with open(out_path, "wb") as fh:
                fh.write(blob)
            written.append(out_path)
        except Exception:
            continue
    return written


