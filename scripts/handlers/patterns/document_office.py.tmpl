def _read_docx(path: str) -> str:
    import docx  # type: ignore
    doc = docx.Document(path)
    parts = []
    for i, p in enumerate(doc.paragraphs):
        if i >= _DOCX_PARA_CAP:
            break
        txt = (p.text or "").strip()
        if txt:
            parts.append(txt)
    # Walk tables too — table cells often contain the real content.
    for tbl in doc.tables:
        for row in tbl.rows:
            for cell in row.cells:
                txt = (cell.text or "").strip()
                if txt:
                    parts.append(txt)
    return "\n".join(parts)


def _images_docx(path: str, out_dir: str) -> list:
    import docx  # type: ignore
    doc = docx.Document(path)
