def _read_pptx(path: str) -> str:
    import pptx  # type: ignore
    prs = pptx.Presentation(path)
    parts = []
    for slide_idx, slide in enumerate(prs.slides):
        if slide_idx >= _PPTX_SLIDE_CAP:
            break
        for shape in slide.shapes:
            try:
                if not shape.has_text_frame:
                    continue
                for para in shape.text_frame.paragraphs:
                    run_text = "".join(run.text or "" for run in para.runs)
                    if run_text.strip():
                        parts.append(run_text)
            except Exception:
                continue
    return "\n".join(parts)


def _images_pptx(path: str, out_dir: str) -> list:
    import pptx  # type: ignore
    from pptx.enum.shapes import MSO_SHAPE_TYPE  # type: ignore
    prs = pptx.Presentation(path)
    stem = Path(path).stem
    written = []
    for slide_idx, slide in enumerate(prs.slides):
        if len(written) >= _IMAGE_CAP:
            break
        for shape_idx, shape in enumerate(slide.shapes):
            if len(written) >= _IMAGE_CAP:
                break
            try:
                if shape.shape_type != MSO_SHAPE_TYPE.PICTURE:
                    continue
                image = shape.image
                blob = image.blob
                ext = (image.ext or "bin").lstrip(".")
                out_path = os.path.join(
                    out_dir,
                    f"{{stem}}--s{{slide_idx + 1:03d}}-i{{shape_idx + 1:02d}}.{{ext}}",
                )
                with open(out_path, "wb") as fh:
                    fh.write(blob)
                written.append(out_path)
            except Exception:
                continue
    return written


