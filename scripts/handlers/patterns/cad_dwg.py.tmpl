def _convert_to_dxf(dwg_path: str, tmp_dir: str):
    """Convert a DWG to an ezdxf Drawing, trying LibreDWG then ODA.

    Returns the ezdxf Drawing on success, None on any failure.
    """
    doc = _convert_via_libredwg(dwg_path, tmp_dir)
    if doc is not None:
        return doc
    return _convert_via_oda(dwg_path)


def read_text(path: str) -> str:
    """Extract text entities from a DWG file via LibreDWG/ODA → DXF.

    Returns:
        Concatenated text entity content as a string, or '' on any failure
        (including no converter installed). Never raises.
    """
    with tempfile.TemporaryDirectory() as tmp_dir:
        doc = _convert_to_dxf(path, tmp_dir)
        if doc is None:
            return ""
        try:
            msp = doc.modelspace()
            parts = []
            for entity in msp:
                try:
                    dxftype = entity.dxftype()
                    if dxftype == "TEXT":
                        val = entity.dxf.text
                        if val and val.strip():
                            parts.append(val)
                    elif dxftype == "MTEXT":
                        val = entity.plain_mtext()
                        if val and val.strip():
                            parts.append(val)
                    elif dxftype == "ATTRIB":
                        val = entity.dxf.text
                        if val and val.strip():
                            parts.append(val)
                except Exception:
                    continue
            return "\n".join(parts)
        except Exception as exc:
            logger.debug("read_text failed for %s: %s", path, exc)
            return ""


def extract_images(path: str, out_dir: str) -> list:
    """Render DWG modelspace to PNG after LibreDWG/ODA → DXF conversion.

    Returns:
        List containing the path of the rendered PNG, or [] on any failure
        (including no converter installed). Never raises.
    """
    with tempfile.TemporaryDirectory() as tmp_dir:
        doc = _convert_to_dxf(path, tmp_dir)
        if doc is None:
            return []
        try:
            from ezdxf.addons.drawing import RenderContext, Frontend
            from ezdxf.addons.drawing.matplotlib import MatplotlibBackend
            import matplotlib.pyplot as plt

            msp = doc.modelspace()
            stem = Path(path).stem
            os.makedirs(out_dir, exist_ok=True)
            out_path = os.path.join(out_dir, f"{{stem}}--page001.png")

            fig = plt.figure()
            ax = fig.add_axes([0, 0, 1, 1])
            ctx = RenderContext(doc)
            out_backend = MatplotlibBackend(ax)
            Frontend(ctx, out_backend).draw_layout(msp, finalize=True)
            fig.savefig(out_path, dpi=150)
            plt.close(fig)
            return [out_path]
        except Exception as exc:
            logger.debug("extract_images failed for %s: %s", path, exc)
            return []
