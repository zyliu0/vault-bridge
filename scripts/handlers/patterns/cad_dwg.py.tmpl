def read_text(path: str) -> str:
    """Extract text entities from a DWG file (TEXT, MTEXT, ATTRIB).

    ezdxf reads DWG natively; the same API applies for both DXF and DWG.

    Returns:
        Concatenated text entity content as a string, or '' on any failure.
        Never raises.
    """
    try:
        import ezdxf
        doc = ezdxf.readfile(path)
        msp = doc.modelspace()
        parts = []
        for entity in msp:
            try:
                dxftype = entity.dxftype()
                if dxftype == "TEXT":
                    val = entity.dxf.text
                    if val and val.strip():
                        parts.append(val)
                elif dxftype == "MTEXT":
                    val = entity.plain_mtext()
                    if val and val.strip():
                        parts.append(val)
                elif dxftype == "ATTRIB":
                    val = entity.dxf.text
                    if val and val.strip():
                        parts.append(val)
            except Exception:
                continue
        return "\n".join(parts)
    except Exception as exc:
        logger.debug("read_text failed for %s: %s", path, exc)
        return ""


