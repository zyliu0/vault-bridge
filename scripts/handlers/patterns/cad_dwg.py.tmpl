def _convert_via_libredwg(dwg_path: str, tmp_dir: str):
    """Convert DWG → ezdxf Drawing using LibreDWG's `dwg2dxf`.

    Returns the ezdxf Drawing on success, None when `dwg2dxf` is
    unavailable or conversion fails. Always the first attempt because
    LibreDWG ships under GPL with no click-through EULA — the auto-
    install path setup can take without asking twice.
    """
    if not shutil.which("dwg2dxf"):
        return None
    try:
        import ezdxf
        # `dwg2dxf foo.dwg` writes `foo.dxf` next to the input. Copy
        # the DWG into our tmp_dir so the sibling write lands there
        # (never mutates the user's archive directory).
        src = Path(dwg_path)
        tmp_dwg = Path(tmp_dir) / src.name
        shutil.copy2(src, tmp_dwg)
        tmp_dxf = tmp_dwg.with_suffix(".dxf")
        proc = subprocess.run(
            ["dwg2dxf", str(tmp_dwg)],
            capture_output=True, text=True, timeout=60,
        )
        if proc.returncode != 0 or not tmp_dxf.exists():
            logger.debug(
                "dwg2dxf rc=%d (stderr=%s) for %s",
                proc.returncode, proc.stderr[:200], dwg_path,
            )
            return None
        return ezdxf.readfile(str(tmp_dxf))
    except Exception as exc:
        logger.debug("libredwg conversion failed for %s: %s", dwg_path, exc)
        return None


def _convert_via_oda(dwg_path: str):
