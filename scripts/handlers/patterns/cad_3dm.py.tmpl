def read_text(path: str) -> str:
    """Extract geometry metadata and notes from a Rhino 3DM file.

    Returns a formatted block with:
    - ApplicationName
    - Notes
    - Object counts by type (Mesh, Curve, Brep, Annotation, Other)
    - Layer names

    Returns:
        Formatted metadata string, or '' on any failure.
        Never raises.
    """
    try:
        import rhino3dm
        model = rhino3dm.File3dm.Read(path)
        if model is None:
            return ""
        lines = []
        # Application name
        try:
            app_name = model.ApplicationName
            if app_name:
                lines.append(f"ApplicationName: {{app_name}}")
        except Exception:
            pass
        # Notes
        try:
            notes = model.Notes
            if notes and notes.strip():
                lines.append(f"Notes: {{notes.strip()}}")
        except Exception:
            pass
        # Object counts by type
        try:
            counts = {{
                "Mesh": 0,
                "Curve": 0,
                "Brep": 0,
                "Annotation": 0,
                "Other": 0,
            }}
            for obj in model.Objects:
                try:
                    geo = obj.Geometry
                    type_name = type(geo).__name__
                    if "Mesh" in type_name:
                        counts["Mesh"] += 1
                    elif "Curve" in type_name or "Line" in type_name:
                        counts["Curve"] += 1
                    elif "Brep" in type_name or "Extrusion" in type_name:
                        counts["Brep"] += 1
                    elif "Annotation" in type_name or "Text" in type_name:
                        counts["Annotation"] += 1
                    else:
                        counts["Other"] += 1
                except Exception:
                    counts["Other"] += 1
            total = sum(counts.values())
            if total > 0:
                count_parts = [f"{{k}}: {{v}}" for k, v in counts.items() if v > 0]
                lines.append(f"Objects ({{total}}): {{', '.join(count_parts)}}")
        except Exception:
            pass
        # Layer names
        try:
            layer_names = []
            for layer in model.Layers:
                name = layer.Name
                if name:
                    layer_names.append(name)
            if layer_names:
                lines.append(f"Layers: {{', '.join(layer_names)}}")
        except Exception:
            pass
        return "\n".join(lines)
    except Exception as exc:
        logger.debug("read_text failed for %s: %s", path, exc)
        return ""


