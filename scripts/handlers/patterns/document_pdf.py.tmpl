        return "\n\n".join(parts)
    except Exception as exc:
        logger.debug("PyPDF2 read failed for %s: %s", path, exc)
        return ""


def extract_images(path: str, out_dir: str) -> list:
    """Extract embedded images from a PDF.

    Uses PyMuPDF (fitz) when available. Falls back to pdfplumber
    page.to_image() rendering when fitz is not installed — this yields
    page snapshots rather than embedded images, but keeps the pipeline
    productive for scanned PDFs.

    Returns:
        List of written image paths, or [] on any failure. Never raises.
    """
    try:
        os.makedirs(out_dir, exist_ok=True)
    except Exception as exc:
        logger.debug("extract_images: mkdir failed for %s: %s", out_dir, exc)
        return []
    stem = Path(path).stem
    written = []

    # Preferred: PyMuPDF extracts true embedded images.
    try:
        import fitz  # type: ignore
        doc = fitz.open(path)
        try:
            for page_idx in range(min(len(doc), _PAGE_CAP_IMAGES)):
                if len(written) >= _IMAGE_CAP:
                    break
                page = doc.load_page(page_idx)
                try:
                    images = page.get_images(full=True)
                except Exception:
