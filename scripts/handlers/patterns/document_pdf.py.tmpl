                        continue
                    out_path = os.path.join(
                        out_dir,
                        f"{{stem}}--p{{page_idx + 1:03d}}-i{{img_idx + 1:02d}}.{{ext}}",
                    )
                    with open(out_path, "wb") as fh:
                        fh.write(data)
                    written.append(out_path)
        finally:
            doc.close()
        if written:
            return written
    except Exception as exc:
        logger.debug("fitz extract failed for %s: %s", path, exc)

    # Fallback: render pages via pdfplumber (requires pdf2image/pillow).
    try:
        import pdfplumber
        with pdfplumber.open(path) as pdf:
            for page_idx, page in enumerate(pdf.pages[:_PAGE_CAP_IMAGES]):
                if len(written) >= _IMAGE_CAP:
                    break
                try:
                    img = page.to_image(resolution=144)
                    out_path = os.path.join(
                        out_dir, f"{{stem}}--page{{page_idx + 1:03d}}.png"
                    )
                    img.save(out_path, format="PNG")
                    written.append(out_path)
                except Exception:
                    continue
        return written
    except Exception as exc:
        logger.debug("pdfplumber render failed for %s: %s", path, exc)
        return written if written else []
